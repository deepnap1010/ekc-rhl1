# ── EKC SmartFactory server env ──────────────────────────────────────────────
# Local dev: copy this file to `server/.env` and fill in real values (server/.env
# is gitignored, so secrets never reach GitHub).
# Production (Render): set these in the service's Environment tab instead — do NOT
# commit real secrets.

# MongoDB Atlas connection string (REQUIRED). The target DB is forced to DB_NAME,
# so any database in the URI path is ignored.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=test

# JWT signing secret (REQUIRED in prod — use a long random string). On Render this
# is auto-generated by the Blueprint (generateValue), so you don't set it by hand.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=12h
REFRESH_EXPIRY=7d

# development | production
NODE_ENV=development

# Comma-separated allowed browser origins. Only matters for a CROSS-origin setup;
# for the single-service Render deploy the UI is same-origin, so you can leave this.
CLIENT_ORIGIN=http://localhost:5173

# First-access bootstrap admin — used ONLY while the `users` collection is empty
# (issues a session without writing a doc; auto-disables once a real user exists).
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@ekc.in
ADMIN_PASSWORD=admin123

# PORT is provided automatically by Render. Locally it defaults to 5000 if unset.
# PORT=5000
